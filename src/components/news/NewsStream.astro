---
import NewsCard from './NewsCard.astro';
import { getNewsPageHref, type AnlikHaberEntry } from '../../data/anlikHaber';

interface Props {
	entries: AnlikHaberEntry[];
	currentPage: number;
	totalPages: number;
}

const { entries, currentPage, totalPages } = Astro.props;
const nextPage = currentPage < totalPages ? currentPage + 1 : null;
const nextPageHref = nextPage ? getNewsPageHref(nextPage) : '';
---

<section class="news-stream" data-news-stream data-current-page={currentPage} data-total-pages={totalPages} data-next-page={nextPageHref}>
	<div class="news-list" data-news-list>
		{entries.map((entry) => <NewsCard entry={entry} />)}
	</div>

	<div class="news-stream-footer">
		{nextPageHref ? (
			<>
				<p class="news-footer-note">Aşağı indikçe yeni paketler yüklenecek. İstersen elle de devam edebilirsin.</p>
				<a class="news-load-more" data-news-next-link href={nextPageHref}>Sonraki haber paketini aç</a>
				<div class="news-sentinel" data-news-sentinel aria-hidden="true"></div>
			</>
		) : (
			<p class="news-footer-note end">Şimdilik arşivin sonuna geldin.</p>
		)}
	</div>
</section>

<script>
	function initNewsStream() {
		document.querySelectorAll('[data-news-stream]').forEach((root) => {
			if (!(root instanceof HTMLElement) || root.dataset.bound === '1') return;
			root.dataset.bound = '1';

			const list = root.querySelector('[data-news-list]');
			const link = root.querySelector('[data-news-next-link]');
			const sentinel = root.querySelector('[data-news-sentinel]');
			if (!(list instanceof HTMLElement) || !(link instanceof HTMLAnchorElement)) return;

			let loading = false;
			let observer = null;

			const setLoadingState = (value) => {
				loading = value;
				root.dataset.loading = value ? '1' : '0';
				link.textContent = value ? 'Yeni haberler yükleniyor…' : 'Sonraki haber paketini aç';
			};

			const stop = () => {
				if (observer) observer.disconnect();
				observer = null;
				root.dataset.nextPage = '';
				link.removeAttribute('data-news-next-link');
				link.setAttribute('aria-disabled', 'true');
				link.classList.add('is-disabled');
				link.textContent = 'Başka paket yok';
				if (sentinel instanceof HTMLElement) sentinel.remove();
			};

			const loadNextPage = async () => {
				const nextHref = root.dataset.nextPage || link.getAttribute('href') || '';
				if (!nextHref || loading) return;
				setLoadingState(true);

				try {
					const response = await fetch(nextHref);
					if (!response.ok) throw new Error(`HTTP ${response.status}`);
					const html = await response.text();
					const parsed = new DOMParser().parseFromString(html, 'text/html');
					const parsedRoot = parsed.querySelector('[data-news-stream]');
					const parsedList = parsedRoot?.querySelector('[data-news-list]');
					if (!(parsedRoot instanceof HTMLElement) || !(parsedList instanceof HTMLElement)) {
						throw new Error('News page structure not found');
					}

					Array.from(parsedList.children).forEach((child) => list.appendChild(child));

					const upcomingHref = parsedRoot.dataset.nextPage || '';
					if (upcomingHref) {
						root.dataset.nextPage = upcomingHref;
						link.href = upcomingHref;
						link.textContent = 'Sonraki haber paketini aç';
					} else {
						stop();
					}
				} catch (error) {
					console.error('Anlık haber paketi yüklenemedi:', error);
					link.textContent = 'Yükleme başarısız, dokunup yeniden dene';
				} finally {
					setLoadingState(false);
				}
			};

			link.addEventListener('click', (event) => {
				event.preventDefault();
				loadNextPage();
			});

			if (sentinel instanceof HTMLElement && 'IntersectionObserver' in window) {
				observer = new IntersectionObserver((entries) => {
					const shouldLoad = entries.some((entry) => entry.isIntersecting);
					if (shouldLoad) loadNextPage();
				}, { rootMargin: '1200px 0px' });
				observer.observe(sentinel);
			}
		});
	}

	initNewsStream();
	document.addEventListener('astro:page-load', initNewsStream);
</script>

<style>
	.news-stream {
		padding-top: 0.4rem;
	}
	.news-list {
		display: grid;
		gap: 0;
	}
	.news-stream-footer {
		display: grid;
		justify-items: center;
		gap: 0.8rem;
		padding: 2rem 0 0.5rem;
	}
	.news-footer-note {
		color: var(--news-muted);
		font-size: 0.9rem;
		text-align: center;
	}
	.news-footer-note.end {
		padding: 0.8rem 0 1.2rem;
	}
	.news-load-more {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.9rem 1.15rem;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--news-border) 80%, transparent);
		background: color-mix(in srgb, var(--news-panel) 88%, transparent);
		color: var(--news-text);
		text-decoration: none;
		font-weight: 700;
	}
	.news-load-more:hover {
		border-color: var(--news-accent);
		color: var(--news-accent);
	}
	.news-load-more.is-disabled {
		opacity: 0.6;
		pointer-events: none;
	}
	.news-sentinel {
		width: 100%;
		height: 1px;
	}
</style>
