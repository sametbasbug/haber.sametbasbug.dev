---
import { formatNewsDate, getNewsCategoryToken, type AnlikHaberEntry } from '../../data/anlikHaber';
import { getNewsArticleHref } from '../../data/newsSite';

interface Props {
	entries: AnlikHaberEntry[];
	sideEntries?: AnlikHaberEntry[];
	emptyTitle?: string;
	emptyDescription?: string;
}

const {
	entries,
	sideEntries = [],
	emptyTitle = 'Henüz yayınlanmış anlık haber yok.',
	emptyDescription = 'İskelet hazır. İlk haber girildiğinde bu akış canlı çalışmaya başlayacak.',
} = Astro.props;

const featuredLeadEntries = entries.slice(0, Math.min(10, entries.length));
const leadEntry = featuredLeadEntries[0];
---

{leadEntry ? (
	<section class="featured-news-grid">
		<div class="featured-lead-card" data-featured-lead>
			{featuredLeadEntries.map((entry, index) => {
				const entryCategoryToken = getNewsCategoryToken(entry.data.category);
				const isActive = index === 0;
				return (
					<a
						href={getNewsArticleHref(entry.id)}
						class={`featured-lead-slide ${isActive ? 'is-active' : ''}`}
						data-featured-slide
						data-index={index}
						aria-hidden={isActive ? 'false' : 'true'}
						tabindex={isActive ? undefined : -1}
					>
						{entry.data.heroImage && <img src={entry.data.heroImage} alt="" loading={index === 0 ? 'eager' : 'lazy'} decoding="async" />}
						<div class="featured-overlay lead"></div>
						<div class="featured-lead-content">
							<div class="featured-lead-topline">
								{entry.data.category && <span class="featured-badge" data-category={entryCategoryToken}>{entry.data.category}</span>}
								{entry.data.breaking && <span class="featured-badge breaking">Son Dakika</span>}
							</div>
							<h2>{entry.data.title}</h2>
							<p>{entry.data.description}</p>
							<div class="featured-meta-row">
								<time datetime={entry.data.pubDate.toISOString()}>{formatNewsDate(entry.data.pubDate)}</time>
								<span>{entry.data.author ?? 'Nyx AI'}</span>
							</div>
						</div>
					</a>
				);
			})}

			{featuredLeadEntries.length > 1 && (
				<div class="featured-lead-nav" aria-label="Öne çıkan haberler">
					{featuredLeadEntries.map((entry, index) => (
						<button
							type="button"
							class={`featured-lead-trigger ${index === 0 ? 'is-active' : ''}`}
							data-featured-trigger
							data-index={index}
							aria-label={`${index + 1}. haber: ${entry.data.title}`}
						>
							{index + 1}
						</button>
					))}
				</div>
			)}
		</div>

		{sideEntries.length > 0 && (
			<section class="featured-side-stack" aria-label="Editörün seçtikleri">
				<div class="featured-side-header">
					<p>Öne çıkanlar</p>
					<h2>Editörün seçtikleri</h2>
				</div>
				<div class="featured-side-list" role="list">
					{sideEntries.map((entry) => (
						<a href={getNewsArticleHref(entry.id)} class="featured-side-card" role="listitem">
							<div class="featured-side-content text-only">
								{entry.data.category && <span class="featured-badge side" data-category={getNewsCategoryToken(entry.data.category)}>{entry.data.category}</span>}
								<h2>{entry.data.title}</h2>
								<p>{entry.data.description}</p>
								<time datetime={entry.data.pubDate.toISOString()}>{formatNewsDate(entry.data.pubDate)}</time>
							</div>
						</a>
					))}
				</div>
			</section>
		)}
	</section>
) : (
	<div class="news-empty-state inner">
		<h2>{emptyTitle}</h2>
		<p>{emptyDescription}</p>
	</div>
)}

<script>
	function initFeaturedLeadCards() {
		document.querySelectorAll('[data-featured-lead]').forEach((root) => {
			if (!(root instanceof HTMLElement) || root.dataset.bound === '1') return;
			root.dataset.bound = '1';

			const slides = Array.from(root.querySelectorAll('[data-featured-slide]'));
			const triggers = Array.from(root.querySelectorAll('[data-featured-trigger]'));
			if (slides.length === 0 || triggers.length === 0) return;

			const setActive = (index) => {
				slides.forEach((slide, slideIndex) => {
					if (!(slide instanceof HTMLElement)) return;
					const active = slideIndex === index;
					slide.classList.toggle('is-active', active);
					slide.setAttribute('aria-hidden', active ? 'false' : 'true');
					if (active) slide.removeAttribute('tabindex');
					else slide.setAttribute('tabindex', '-1');
				});
				triggers.forEach((trigger, triggerIndex) => {
					if (!(trigger instanceof HTMLElement)) return;
					trigger.classList.toggle('is-active', triggerIndex === index);
				});
			};

			setActive(0);

			triggers.forEach((trigger, index) => {
				if (!(trigger instanceof HTMLButtonElement)) return;
				trigger.addEventListener('mouseenter', () => setActive(index));
				trigger.addEventListener('focus', () => setActive(index));
				trigger.addEventListener('click', () => setActive(index));
			});
		});
	}

	initFeaturedLeadCards();
	document.addEventListener('astro:page-load', initFeaturedLeadCards);
</script>

<style>
	.featured-news-grid {
		display: grid;
		grid-template-columns: minmax(0, 2fr) 280px;
		gap: 0.85rem;
		padding-top: 0.24rem;
	}
	.featured-side-stack {
		position: relative;
		display: grid;
		gap: 0.8rem;
		align-content: start;
	}
	.featured-side-header {
		position: absolute;
		top: -3.2rem;
		left: 0;
		right: 0;
		display: grid;
		gap: 0.18rem;
		padding: 0 0.1rem;
	}
	.featured-side-header p {
		margin: 0;
		font-size: 0.68rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--news-accent-soft);
	}
	.featured-side-header h2 {
		margin: 0;
		font-size: 1rem;
		line-height: 1.2;
		color: var(--news-text);
	}
	.featured-side-list {
		display: grid;
		gap: 0.8rem;
	}
	.featured-side-card,
	.featured-lead-card {
		position: relative;
		display: block;
		overflow: hidden;
		border-radius: 1.15rem;
		border: 1px solid color-mix(in srgb, var(--news-border) 80%, rgba(255,255,255,0.08));
		background: #0b0b0b;
		text-decoration: none;
		box-shadow: var(--news-shadow);
		transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
	}
	.featured-lead-card {
		min-height: 400px;
	}
	.featured-side-card {
		overflow: visible;
		min-height: 0;
		background: color-mix(in srgb, var(--news-panel) 96%, transparent);
		box-shadow: none;
	}
	.featured-side-card:hover,
	.featured-lead-card:hover {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--news-accent) 35%, var(--news-border));
		box-shadow: 0 22px 60px rgba(0,0,0,0.26);
	}
	.featured-side-card:hover {
		box-shadow: 0 12px 26px rgba(0,0,0,0.12);
	}
	:global(html[data-theme='light']) .featured-side-card,
	:global(html[data-theme='light']) .featured-lead-card {
		box-shadow: 0 14px 32px rgba(37, 28, 18, 0.08);
	}
	:global(html[data-theme='light']) .featured-side-card {
		background: rgba(255,255,255,0.82);
		box-shadow: 0 8px 18px rgba(37, 28, 18, 0.05);
	}
	:global(html[data-theme='light']) .featured-side-card:hover,
	:global(html[data-theme='light']) .featured-lead-card:hover {
		box-shadow: 0 18px 40px rgba(37, 28, 18, 0.12);
	}
	.featured-side-card img,
	.featured-lead-card img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		filter: saturate(0.92) brightness(0.78);
		transform: scale(1.01);
	}
	.featured-lead-slide {
		position: absolute;
		inset: 0;
		display: block;
		opacity: 0;
		pointer-events: none;
		transition: opacity 220ms ease;
	}
	.featured-lead-slide.is-active {
		opacity: 1;
		pointer-events: auto;
		z-index: 1;
	}
	.featured-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(0,0,0,0.03) 0%, rgba(0,0,0,0.82) 100%);
	}
	.featured-overlay.lead {
		background: linear-gradient(180deg, rgba(0,0,0,0.03) 0%, rgba(0,0,0,0.82) 100%);
	}
	.featured-lead-content,
	.featured-side-content {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 2;
		padding: 1rem 1.05rem;
	}
	.featured-lead-content {
		padding-bottom: 3.35rem;
	}
	.featured-side-content.text-only {
		position: static;
		padding: 0.95rem 0.95rem 0.9rem;
	}
	.featured-lead-topline,
	.featured-meta-row {
		display: flex;
		align-items: center;
		gap: 0.48rem;
		flex-wrap: wrap;
	}
	.featured-meta-row {
		margin-top: 0.58rem;
		font-size: 0.74rem;
		color: rgba(255,255,255,0.7);
	}
	.featured-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.22rem 0.48rem;
		border-radius: 999px;
		background: rgba(255,255,255,0.12);
		border: 1px solid rgba(255,255,255,0.12);
		color: #fff;
		font-size: 0.64rem;
		font-weight: 800;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		backdrop-filter: blur(6px);
	}
	.featured-badge.breaking {
		background: rgba(220, 38, 38, 0.88);
		border-color: rgba(248, 113, 113, 0.45);
	}
	.featured-badge[data-category='siyaset'],
	.featured-badge.side[data-category='siyaset'] {
		background: rgba(249, 115, 96, 0.16);
		border-color: rgba(249, 115, 96, 0.28);
		color: #fff2ef;
	}
	.featured-badge[data-category='ekonomi'],
	.featured-badge.side[data-category='ekonomi'] {
		background: rgba(242, 185, 75, 0.18);
		border-color: rgba(242, 185, 75, 0.28);
		color: #fff8ea;
	}
	.featured-badge[data-category='turkiye'],
	.featured-badge.side[data-category='turkiye'] {
		background: rgba(251, 113, 133, 0.18);
		border-color: rgba(251, 113, 133, 0.28);
		color: #fff1f4;
	}
	.featured-badge[data-category='dunya'],
	.featured-badge.side[data-category='dunya'] {
		background: rgba(96, 165, 250, 0.18);
		border-color: rgba(96, 165, 250, 0.28);
		color: #eef6ff;
	}
	.featured-badge[data-category='teknoloji'],
	.featured-badge.side[data-category='teknoloji'] {
		background: rgba(52, 211, 153, 0.18);
		border-color: rgba(52, 211, 153, 0.28);
		color: #ecfff8;
	}
	.featured-lead-content h2 {
		margin: 0.45rem 0 0;
		font-size: clamp(1.9rem, 3.2vw, 3.1rem);
		line-height: 0.96;
		letter-spacing: -0.045em;
		color: #fff;
		max-width: 11ch;
	}
	.featured-lead-content p {
		margin-top: 0.58rem;
		max-width: 58ch;
		color: rgba(255,255,255,0.84);
		font-size: 0.96rem;
		line-height: 1.58;
	}
	.featured-side-content h2 {
		margin: 0.58rem 0 0;
		font-size: 1.02rem;
		line-height: 1.16;
		color: var(--news-text);
		letter-spacing: -0.03em;
	}
	.featured-side-content p {
		margin: 0.5rem 0 0;
		font-size: 0.84rem;
		line-height: 1.5;
		color: var(--news-muted-strong);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.featured-side-content time {
		display: inline-block;
		margin-top: 0.55rem;
		font-size: 0.73rem;
		color: var(--news-muted);
	}
	.featured-lead-nav {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 3;
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		padding: 0.78rem 0.95rem 0.9rem;
		justify-content: flex-start;
		pointer-events: none;
	}
	.featured-lead-trigger {
		pointer-events: auto;
		appearance: none;
		border: 0;
		min-width: 2rem;
		height: 2rem;
		padding: 0 0.55rem;
		border-radius: 0.42rem;
		background: rgba(18, 18, 20, 0.82);
		color: rgba(255,255,255,0.82);
		font-size: 0.9rem;
		font-weight: 800;
		cursor: pointer;
		transition: background-color 160ms ease, color 160ms ease, transform 160ms ease;
	}
	.featured-lead-trigger:hover,
	.featured-lead-trigger:focus-visible,
	.featured-lead-trigger.is-active {
		background: #1f5ca8;
		color: #fff;
		transform: translateY(-1px);
	}
	:global(html[data-theme='light']) .featured-lead-trigger {
		background: rgba(32, 34, 40, 0.78);
		color: rgba(255,255,255,0.92);
	}
	:global(html[data-theme='light']) .featured-lead-trigger:hover,
	:global(html[data-theme='light']) .featured-lead-trigger:focus-visible,
	:global(html[data-theme='light']) .featured-lead-trigger.is-active {
		background: #2f6fbe;
	}
	.news-empty-state.inner {
		padding: 1rem 0;
	}
	.news-empty-state.inner h2 {
		font-size: 1.5rem;
		margin-bottom: 0.45rem;
	}
	.news-empty-state.inner p {
		color: var(--news-muted-strong);
		max-width: 56ch;
	}
	@media (max-width: 1080px) {
		.featured-news-grid {
			grid-template-columns: 1fr;
		}
		.featured-side-header {
			position: static;
			padding: 0.2rem 0.1rem 0;
		}
	}
	@media (max-width: 700px) {
		.featured-lead-card {
			min-height: 300px;
		}
		.featured-news-grid {
			grid-template-columns: 1fr;
		}
		.featured-lead-content,
		.featured-side-content {
			padding: 0.85rem;
		}
		.featured-side-content.text-only {
			padding: 0.9rem;
		}
		.featured-lead-content {
			padding-bottom: 3.1rem;
		}
		.featured-lead-nav {
			padding: 0.8rem 0.85rem;
			gap: 0.3rem;
		}
		.featured-lead-trigger {
			min-width: 1.8rem;
			height: 1.8rem;
			font-size: 0.82rem;
		}
		.featured-lead-content h2 {
			font-size: 1.36rem;
			max-width: none;
		}
		.featured-lead-content p {
			font-size: 0.86rem;
			line-height: 1.5;
		}
	}
</style>
