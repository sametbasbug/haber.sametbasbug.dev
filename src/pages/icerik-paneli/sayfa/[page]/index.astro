---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import AdminNewsPanelStream from '../../../../components/news/AdminNewsPanelStream.astro';
import { getPublishedAnlikHaber } from '../../../../data/anlikHaber';
import { getNewsPanelHref } from '../../../../data/newsSite';

const PAGE_SIZE = 10;

export async function getStaticPaths() {
  const pageSize = 10;
  const entries = await getPublishedAnlikHaber();
  const totalPages = Math.max(1, Math.ceil(entries.length / pageSize));
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => ({
    params: { page: String(index + 2) },
  }));
}

const entries = await getPublishedAnlikHaber();
const currentPage = Number(Astro.params.page ?? '1');
const totalPages = Math.max(1, Math.ceil(entries.length / PAGE_SIZE));
const start = (currentPage - 1) * PAGE_SIZE;
const pageEntries = entries.slice(start, start + PAGE_SIZE);
const nextPageHref = currentPage < totalPages ? getNewsPanelHref(currentPage + 1) : '';
const title = `Anlık Haber İçerik Paneli · Sayfa ${currentPage}`;
const description = 'Anlık Haber içeriklerini hızlıca gözden geçirmek için gizli iç panel.';
---

<BaseLayout shellLayout={true} title={title} description={description} noindex={true}>
  <section class="news-admin-panel">
    <AdminNewsPanelStream entries={pageEntries} currentPage={currentPage} totalPages={totalPages} nextPageHref={nextPageHref} />
  </section>
</BaseLayout>

<style>
  :global(body) { background: #0b0b0c; }
  :global(html[data-theme='light'] body) { background: #f3efe8; }
  .news-admin-panel {
    width: min(100%, 1240px);
    margin: 0 auto;
    padding: 1.2rem 1rem 2rem;
    color: #f5f5f3;
  }
  :global(html[data-theme='light']) .news-admin-panel { color: #141210; }
  @media (max-width: 760px) {
    .news-admin-panel { padding-left: 0.8rem; padding-right: 0.8rem; }
  }
</style>
