---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getMainSiteUrl, getNewsHomeHref } from '../data/newsSite';

const title = '404';
const description = 'Aradığın sayfa haber akışında yok ya da taşınmış olabilir.';
const newsHomeHref = getNewsHomeHref();
const blogHomeHref = getMainSiteUrl();
---

<BaseLayout shellLayout={true} title={title} description={description} noindex={true}>
  <section class="news-404-shell">
    <div class="news-404-card">
      <p class="kicker">Sayfa kayıp</p>
      <h1>404</h1>
      <p class="summary">Aradığın sayfa burada değil. Link eskimiş olabilir ya da haber çoktan başka bir adrese taşınmış olabilir.</p>

      <div class="actions">
        <a href={newsHomeHref} class="primary">Anlık Haber ana sayfası</a>
        <a href="/rss.xml" class="secondary">RSS akışı</a>
        <a href={blogHomeHref} class="secondary">Ana siteye dön</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  :global(body) {
    background: #050505;
  }
  :global(html[data-theme='light'] body) {
    background: #f4efe7;
  }
  .news-404-shell {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 1.25rem;
    background:
      radial-gradient(circle at top center, rgba(255,255,255,0.05), transparent 0 34%),
      radial-gradient(circle at 20% 0%, rgba(244, 106, 90, 0.08), transparent 0 22%),
      #050505;
  }
  .news-404-card {
    width: min(100%, 720px);
    padding: 2rem;
    border-radius: 1.4rem;
    border: 1px solid rgba(255,255,255,0.08);
    background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
    box-shadow: 0 18px 50px rgba(0,0,0,0.22);
    color: #f5f5f3;
  }
  .kicker {
    margin: 0 0 0.55rem;
    color: #ff9a86;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  h1 {
    margin: 0;
    font-size: clamp(4rem, 14vw, 7rem);
    line-height: 0.92;
    letter-spacing: -0.08em;
  }
  .summary {
    margin: 1rem 0 0;
    max-width: 48ch;
    color: rgba(255,255,255,0.74);
    font-size: 1rem;
    line-height: 1.7;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.4rem;
  }
  .actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    padding: 0.65rem 1rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    transition: 160ms ease;
  }
  .actions a.primary {
    background: #f46a5a;
    color: white;
  }
  .actions a.primary:hover {
    background: #ff7d6e;
  }
  .actions a.secondary {
    color: #f5f5f3;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
  }
  .actions a.secondary:hover {
    border-color: #f46a5a;
    color: white;
  }
  :global(html[data-theme='light']) .news-404-shell {
    background: #f4efe7;
  }
  :global(html[data-theme='light']) .news-404-card {
    color: #141210;
    border-color: rgba(95,76,55,0.14);
    background: linear-gradient(180deg, rgba(255,255,255,0.78), rgba(255,255,255,0.62));
    box-shadow: 0 18px 44px rgba(44, 32, 18, 0.08);
  }
  :global(html[data-theme='light']) .summary {
    color: rgba(20,18,16,0.7);
  }
  :global(html[data-theme='light']) .actions a.secondary {
    color: #141210;
    border-color: rgba(95,76,55,0.14);
    background: rgba(255,255,255,0.68);
  }
  @media (max-width: 640px) {
    .news-404-card {
      padding: 1.35rem;
      border-radius: 1.1rem;
    }
    .actions {
      display: grid;
      grid-template-columns: 1fr;
    }
    .actions a {
      width: 100%;
    }
  }
</style>
